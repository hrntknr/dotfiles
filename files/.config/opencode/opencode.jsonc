{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [
    "opencode",
  ],
  "model": "openai/gpt-5.5-fast",
  "small_model": "openai/gpt-5.4-mini",
  "permission": {
    "external_directory": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.vault_password": "deny",
    },
    "edit": {
      "*": "allow",
      "*.env": "deny",
      "*.vault_password": "deny",
    },
  },
  "provider": {
    "localllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local LLM",
      "options": {
        "baseURL": "https://api.llm.pm1.hrntknr.net/v1"
      },
      "models": {
        "local": {
          "name": "Qwen3.6 35B A3B",
          "limit": {
            "context": 131072,
            "output": 16384,
          },
        },
      },
    },
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
  ],
}
