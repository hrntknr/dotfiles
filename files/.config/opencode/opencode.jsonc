{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [
    "opencode",
  ],
  "model": "openai/gpt-5.5-fast",
  "small_model": "openai/gpt-5.4-mini",
  "permission": {
    "external_directory": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.vault_password": "deny",
    },
    "edit": {
      "*": "allow",
      "*.env": "deny",
      "*.vault_password": "deny",
    },
  },
}
