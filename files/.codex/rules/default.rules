prefix_rule(pattern = ["kubectl", "events"], decision = "allow")
prefix_rule(pattern = ["kubectl", "explain"], decision = "allow")
prefix_rule(pattern = ["kubectl", "wait"], decision = "allow")
prefix_rule(pattern = ["kubectl", "kustomize"], decision = "allow")
prefix_rule(pattern = ["kubectl", "config", "view"], decision = "allow")
prefix_rule(pattern = ["kubectl", "config", "get-contexts"], decision = "allow")
prefix_rule(pattern = ["kubectl", "config", "current-context"], decision = "allow")
prefix_rule(pattern = ["kubectl", "config", "get-clusters"], decision = "allow")
prefix_rule(pattern = ["kubectl", "config", "get-users"], decision = "allow")
prefix_rule(pattern = ["kubectl", "auth", "can-i"], decision = "allow")
prefix_rule(pattern = ["kubectl", "auth", "whoami"], decision = "allow")
prefix_rule(pattern = ["terraform", "plan"], decision = "allow")
prefix_rule(pattern = ["terraform", "show"], decision = "allow")
prefix_rule(pattern = ["terraform", "validate"], decision = "allow")
prefix_rule(pattern = ["terraform", "fmt"], decision = "allow")
prefix_rule(pattern = ["ansible-lint"], decision = "allow")
