{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ]
  },
  "language": "日本語",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.kube/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.kube/**)",
      "Write(~/.ssh/**)",
      "Write(~/.kube/**)"
    ],
    "allow": [
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl events:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl api-resources:*)",
      "Bash(kubectl api-versions:*)",
      "Bash(kubectl version:*)",
      "Bash(kubectl cluster-info:*)",
      "Bash(kubectl diff:*)",
      "Bash(kubectl wait:*)",
      "Bash(kubectl kustomize:*)",
      "Bash(kubectl config view:*)",
      "Bash(kubectl config get-contexts:*)",
      "Bash(kubectl config current-context:*)",
      "Bash(kubectl config get-clusters:*)",
      "Bash(kubectl config get-users:*)",
      "Bash(kubectl auth can-i:*)",
      "Bash(kubectl auth whoami:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform show:*)",
      "Bash(terraform output:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform version:*)",
      "Bash(terraform graph:*)",
      "Bash(terraform state list:*)",
      "Bash(terraform state show:*)",
      "Bash(terraform state pull:*)",
      "Bash(terraform workspace list:*)",
      "Bash(terraform workspace show:*)",
      "Bash(terraform providers schema:*)",
      "Bash(helm list:*)",
      "Bash(helm ls:*)",
      "Bash(helm status:*)",
      "Bash(helm get:*)",
      "Bash(helm history:*)",
      "Bash(helm show:*)",
      "Bash(helm template:*)",
      "Bash(helm diff:*)",
      "Bash(helm repo list:*)",
      "Bash(helm search:*)",
      "Bash(helm version:*)",
      "Bash(helm env:*)",
      "Bash(helm plugin list:*)",
      "Bash(ansible-lint:*)",
      "Bash(ansible-inventory:*)",
      "Bash(ansible-config:*)",
      "Bash(ansible-doc:*)",
      "Bash(ansible-galaxy list:*)",
      "Bash(ansible-vault view:*)"
    ],
    "ask": [
      "Bash(ssh:*)",
      "Bash(kubectl:*)",
      "Bash(terraform:*)",
      "Bash(helm:*)",
      "Bash(ansible:*)",
      "Bash(ansible-playbook:*)",
      "Bash(ansible-galaxy:*)",
      "Bash(ansible-vault:*)"
    ]
  },
  "model": "opus[1m]",
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  }
}
