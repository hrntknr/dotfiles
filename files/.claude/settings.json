{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "permission_prompt|idle_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ]
  },
  "language": "日本語",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "auto",
    "deny": ["Bash(gh auth *)"],
    "allow": []
  },
  "model": "opus[1m]",
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "enableWeakerNetworkIsolation": true,
    "filesystem": {
      "allowRead": ["~/Library/Caches/go-build"],
      "denyRead": ["~/.*"],
      "denyWrite": ["~/.*"]
    },
    "excludedCommands": [
      "git *",
      "gh *",
      "kubectl get *",
      "kubectl describe *",
      "kubectl logs *",
      "kubectl top *",
      "kubectl events *",
      "kubectl explain *",
      "kubectl wait *",
      "kubectl kustomize *",
      "kubectl config view *",
      "kubectl config get-contexts *",
      "kubectl config current-context *",
      "kubectl config get-clusters *",
      "kubectl config get-users *",
      "kubectl auth can-i *",
      "kubectl auth whoami *",
      "terraform plan *",
      "terraform show *",
      "terraform validate *",
      "terraform fmt *",
      "ansible-lint *",
      "ansible-inventory *",
      "ansible-config *",
      "ansible-doc *"
    ]
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  }
}
