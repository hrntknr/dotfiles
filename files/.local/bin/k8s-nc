#!/bin/sh
set -eu

host=${1%.k8s}

case "$host" in
  *.*.*)
    deployment=${host%%.*}
    rest=${host#*.}
    namespace=${rest%%.*}
    context=${rest#*.}
    ;;
  *.*)
    deployment=${host%%.*}
    namespace=${host#*.}
    context=
    ;;
  *)
    deployment=$host
    namespace=
    context=
    ;;
esac

set --

if [ -n "$context" ]; then
  set -- "$@" --context "$context"
fi

if [ -n "$namespace" ]; then
  set -- "$@" -n "$namespace"
fi

exec kubectl "$@" exec -it "deploy/$deployment" -- /usr/bin/nc localhost 22
