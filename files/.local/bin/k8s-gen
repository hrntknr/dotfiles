#!/usr/bin/env sh
set -eu

usage() {
  status=${1:-1}
  prog=${0##*/}
  cat >&2 <<EOF
Usage:
  $prog [options] [namespace/]name

Options:
  --base sh-mini|sh-full|job     Select the base resource and image (default: sh-mini)
  --gpu                          Add the GPU preset
  --mncore2                      Add the MN-Core 2 preset
  --node <node>                  Pin the pod to a node
  --priority <class>             Set priorityClassName
  --pvc <pvc>                    Mount an existing PVC
  --persist-host-keys            Persist SSH host keys
  --no-persist-host-keys         Do not persist SSH host keys
  -h, --help                     Show this help

Examples:
  $prog default/test
  $prog --base sh-full --gpu default/test
  $prog --base job default/test
  $prog --node gpu-node-1 --priority high --pvc test-data default/test
EOF
  exit "$status"
}

base=sh-mini
gpu=0
mncore2=0
node_name=
priority_class_name=
pvc_name=
persist_host_keys=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h | --help)
      usage 0
      ;;
    --base)
      shift
      [ "$#" -gt 0 ] || usage
      base=$1
      ;;
    --gpu)
      gpu=1
      ;;
    --mncore2)
      mncore2=1
      ;;
    --node)
      shift
      [ "$#" -gt 0 ] || usage
      node_name=$1
      ;;
    --priority)
      shift
      [ "$#" -gt 0 ] || usage
      priority_class_name=$1
      ;;
    --pvc)
      shift
      [ "$#" -gt 0 ] || usage
      pvc_name=$1
      ;;
    --persist-host-keys)
      persist_host_keys=1
      ;;
    --no-persist-host-keys)
      persist_host_keys=0
      ;;
    --)
      shift
      break
      ;;
    -*)
      usage
      ;;
    *)
      break
      ;;
  esac
  shift
done

[ "$#" -eq 1 ] || usage

case "$base" in
  sh-mini)
    base_dir_name=sh-mini
    base_api_version=apps/v1
    base_kind=Deployment
    ;;
  sh-full)
    base_dir_name=sh-full
    base_api_version=apps/v1
    base_kind=Deployment
    ;;
  job)
    base_dir_name=job
    base_api_version=batch/v1
    base_kind=Job
    ;;
  *)
    usage
    ;;
esac

target=$1

case "$target" in
  */*)
    namespace=${target%%/*}
    name=${target#*/}
    [ -n "$namespace" ] || usage
    ;;
  *)
    namespace=
    name=$target
    ;;
esac

[ -n "$name" ] || usage
case "$name" in
  */*) usage ;;
esac

if [ -n "$priority_class_name" ]; then
  case "$priority_class_name" in
    *[!A-Za-z0-9.-]* | [!A-Za-z0-9]* | *[!A-Za-z0-9])
      usage
      ;;
  esac
fi

if [ -n "$node_name" ]; then
  case "$node_name" in
    *[!A-Za-z0-9._-]* | [!A-Za-z0-9]* | *[!A-Za-z0-9])
      usage
      ;;
  esac
fi

if [ -n "$pvc_name" ]; then
  case "$pvc_name" in
    *[!a-z0-9.-]* | [!a-z0-9]* | *[!a-z0-9])
      usage
      ;;
  esac
fi

NAMESPACE=$namespace
NAME=$name
NODE_NAME=$node_name
PRIORITY_CLASS_NAME=$priority_class_name
PVC_NAME=$pvc_name
BASE_API_VERSION=$base_api_version
BASE_KIND=$base_kind
export NAMESPACE NAME NODE_NAME PRIORITY_CLASS_NAME PVC_NAME BASE_API_VERSION BASE_KIND

script_dir=$(dirname "$0")/k8s
base_dir=$script_dir/bases/$base_dir_name
tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT INT TERM

[ -d "$base_dir" ] || usage
cp -R "$base_dir"/. "$tmp_dir/"

if [ -n "$namespace" ]; then
  cat >>"$tmp_dir/kustomization.yaml" <<'EOF'
namespace: ${NAMESPACE}
EOF
fi

components_added=0

add_opt() {
  opt=$1
  opt_dir=$script_dir/opts/$opt
  component_dir=$tmp_dir/opts/$opt

  [ -d "$opt_dir" ] || usage

  mkdir -p "$component_dir"
  cp -R "$opt_dir"/. "$component_dir/"

  if [ -f "$component_dir/setup.sh" ]; then
    K8S_GEN_TMP_DIR=$tmp_dir \
    K8S_GEN_OPT_DIR=$opt_dir \
    K8S_GEN_COMPONENT_DIR=$component_dir \
      sh "$component_dir/setup.sh"
  fi

  if [ "$components_added" -eq 0 ]; then
    echo "components:" >>"$tmp_dir/kustomization.yaml"
    components_added=1
  fi

  echo "  - opts/$opt" >>"$tmp_dir/kustomization.yaml"
}

if [ "$persist_host_keys" -eq 1 ]; then
  add_opt persist-host-keys
fi

if [ "$gpu" -eq 1 ]; then
  add_opt gpu
fi

if [ "$mncore2" -eq 1 ]; then
  add_opt mncore2
fi

if [ -n "$node_name" ]; then
  add_opt node
fi

if [ -n "$priority_class_name" ]; then
  add_opt priority
fi

if [ -n "$pvc_name" ]; then
  add_opt pvc
fi

find "$tmp_dir" -type f \( -name '*.yaml' -o -name '*.yml' \) | while IFS= read -r file; do
  tmp_file=$file.base-env
  envsubst '$BASE_API_VERSION $BASE_KIND' <"$file" >"$tmp_file"
  mv "$tmp_file" "$file"
done

kustomize build "$tmp_dir" | envsubst '$NAMESPACE $NAME $PVC_NAME'
