#!/usr/bin/env sh
set -eu

usage() {
  status=${1:-1}
  prog=${0##*/}
  cat >&2 <<EOF
Usage:
  $prog [options] [namespace/]name

Options:
  --full                         Use the full image tag and persist host keys
  --mini                         Use the mini image tag and do not persist host keys
  --tag=full|mini                Use a specific image tag
  --gpu                          Add the GPU preset
  --mncore2                      Add the MN-Core 2 preset
  --node <node>                  Pin the pod to a node
  --node=<node>                  Pin the pod to a node
  --priority <class>             Set priorityClassName
  --priority=<class>             Set priorityClassName
  --pvc <pvc>                    Mount an existing PVC
  --pvc=<pvc>                    Mount an existing PVC
  --persist-host-keys            Persist SSH host keys
  --no-persist-host-keys         Do not persist SSH host keys
  -h, --help                     Show this help

Examples:
  $prog default/test
  $prog --full --gpu default/test
  $prog --node=gpu-node-1 --priority=high --pvc=test-data default/test
EOF
  exit "$status"
}

image_tag=mini
gpu=0
mncore2=0
node_name=
priority_class_name=
pvc_name=
persist_host_keys=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h | --help)
      usage 0
      ;;
    --full)
      image_tag=full
      persist_host_keys=1
      ;;
    --mini)
      image_tag=mini
      persist_host_keys=0
      ;;
    --tag=full | --tag=mini)
      image_tag=${1#--tag=}
      ;;
    --tag=*)
      usage
      ;;
    --gpu)
      gpu=1
      ;;
    --mncore2)
      mncore2=1
      ;;
    --node)
      shift
      [ "$#" -gt 0 ] || usage
      node_name=$1
      ;;
    --node=*)
      node_name=${1#--node=}
      [ -n "$node_name" ] || usage
      ;;
    --priority)
      shift
      [ "$#" -gt 0 ] || usage
      priority_class_name=$1
      ;;
    --priority=*)
      priority_class_name=${1#--priority=}
      [ -n "$priority_class_name" ] || usage
      ;;
    --pvc)
      shift
      [ "$#" -gt 0 ] || usage
      pvc_name=$1
      ;;
    --pvc=*)
      pvc_name=${1#--pvc=}
      [ -n "$pvc_name" ] || usage
      ;;
    --persist-host-keys)
      persist_host_keys=1
      ;;
    --no-persist-host-keys)
      persist_host_keys=0
      ;;
    --)
      shift
      break
      ;;
    -*)
      usage
      ;;
    *)
      break
      ;;
  esac
  shift
done

[ "$#" -eq 1 ] || usage

target=$1

case "$target" in
  */*)
    namespace=${target%%/*}
    name=${target#*/}
    [ -n "$namespace" ] || usage
    ;;
  *)
    namespace=
    name=$target
    ;;
esac

[ -n "$name" ] || usage
case "$name" in
  */*) usage ;;
esac

if [ -n "$priority_class_name" ]; then
  case "$priority_class_name" in
    *[!A-Za-z0-9.-]* | [!A-Za-z0-9]* | *[!A-Za-z0-9])
      usage
      ;;
  esac
fi

if [ -n "$node_name" ]; then
  case "$node_name" in
    *[!A-Za-z0-9._-]* | [!A-Za-z0-9]* | *[!A-Za-z0-9])
      usage
      ;;
  esac
fi

if [ -n "$pvc_name" ]; then
  case "$pvc_name" in
    *[!a-z0-9.-]* | [!a-z0-9]* | *[!a-z0-9])
      usage
      ;;
  esac
fi

NAMESPACE=$namespace
NAME=$name
IMAGE_TAG=$image_tag
NODE_NAME=$node_name
PRIORITY_CLASS_NAME=$priority_class_name
PVC_NAME=$pvc_name
export NAMESPACE NAME IMAGE_TAG NODE_NAME PRIORITY_CLASS_NAME PVC_NAME

script_dir=$(dirname "$0")/k8s
tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT INT TERM

cp "$script_dir/deployment.yaml" "$script_dir/kustomization.yaml" "$tmp_dir/"

if [ -n "$namespace" ]; then
  cat >>"$tmp_dir/kustomization.yaml" <<'EOF'
namespace: ${NAMESPACE}
EOF
fi

components_added=0

add_preset() {
  preset=$1
  preset_dir=$script_dir/presets/$preset
  component_dir=$tmp_dir/presets/$preset

  [ -d "$preset_dir" ] || usage

  mkdir -p "$component_dir"
  cp -R "$preset_dir"/. "$component_dir/"

  if [ -f "$component_dir/setup.sh" ]; then
    K8S_GEN_TMP_DIR=$tmp_dir \
    K8S_GEN_PRESET_DIR=$preset_dir \
    K8S_GEN_COMPONENT_DIR=$component_dir \
      sh "$component_dir/setup.sh"
  fi

  if [ "$components_added" -eq 0 ]; then
    echo "components:" >>"$tmp_dir/kustomization.yaml"
    components_added=1
  fi

  echo "  - presets/$preset" >>"$tmp_dir/kustomization.yaml"
}

if [ "$persist_host_keys" -eq 1 ]; then
  add_preset persist-host-keys
fi

if [ "$gpu" -eq 1 ]; then
  add_preset gpu
fi

if [ "$mncore2" -eq 1 ]; then
  add_preset mncore2
fi

if [ -n "$node_name" ]; then
  add_preset node
fi

if [ -n "$priority_class_name" ]; then
  add_preset priority
fi

if [ -n "$pvc_name" ]; then
  add_preset pvc
fi

kustomize build "$tmp_dir" | envsubst '$NAMESPACE $NAME $IMAGE_TAG $PVC_NAME'
