#!/bin/sh
set -eu

is_ssh_session() {
  [ -n "${SSH_CONNECTION:-}${SSH_CLIENT:-}${SSH_TTY:-}" ]
}

emit_open_uri() {
  for uri in "$@"; do
    encoded=$(printf '%s' "$uri" | base64 | tr -d '\n')

    if [ -n "${TMUX:-}" ]; then
      printf '\033Ptmux;\033\033]1337;SetUserVar=open-uri=%s\a\033\\' "$encoded"
      printf '\033Ptmux;\033\033]8;;%s\a%s\033]8;;\a\033\\\n' "$uri" "$uri"
    else
      printf '\033]1337;SetUserVar=open-uri=%s\a' "$encoded"
      printf '\033]8;;%s\a%s\033]8;;\a\n' "$uri" "$uri"
    fi
  done
}

open_with_system_opener() {
  case "$(uname -s)" in
    Darwin)
      exec /usr/bin/open "$@"
      ;;
    Linux)
      for opener in /usr/bin/xdg-open /bin/xdg-open; do
        if [ -x "$opener" ]; then
          exec "$opener" "$@"
        fi
      done
      ;;
  esac

  printf '%s\n' 'open: no system opener found' >&2
  exit 1
}

if is_ssh_session; then
  emit_open_uri "$@"
else
  open_with_system_opener "$@"
fi
